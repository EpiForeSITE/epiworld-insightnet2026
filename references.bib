@article{huangEndogenousCompetitionUnderrealized2025,
  title = {Endogenous Competition and the Underrealized Reproduction of Infectious Diseases},
  author = {Huang, Peng and Almquist, Zack W. and Butts, Carter T.},
  year = 2025,
  month = jun,
  journal = {Proceedings of the National Academy of Sciences},
  volume = {122},
  number = {23},
  pages = {e2502676122},
  publisher = {Proceedings of the National Academy of Sciences},
  doi = {10.1073/pnas.2502676122},
  url = {https://www.pnas.org/doi/full/10.1073/pnas.2502676122},
  urldate = {2025-07-07},
  abstract = {Scientific inquiry about the transmissibility of infectious diseases is largely based on the basic reproduction number (R0) and its derivations. This paper describes a mechanism overlooked in most conventional analyses, in which a disease can endogenously ``compete'' with itself when multiple infectious individuals race to infect the same susceptible individual, thereby reducing the effective reproductive rate. Utilizing an empirically calibrated network epidemiological model of wild-type COVID-19 diffusion in its early pandemic, we show that the mechanism would be expected to reduce its reproductive rate by an average of 39\%. Simulation experiments further identify different types of endogenous competition mechanisms and their relative effect sizes. We highlight the incorporation of endogenous competition mechanism as a necessary step in realistically modeling the reproduction process of infectious diseases.},
  file = {/Users/u6039184/Zotero/storage/J3WC8Q8S/Huang et al. - 2025 - Endogenous competition and the underrealized repro.pdf;/Users/u6039184/Zotero/storage/TFDGNLYH/pnas.2502676122.sapp.pdf}
}


